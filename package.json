{
  "name": "recall-pi",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test --experimental-transform-types .pi/extensions/test/subagent-env.test.ts",
    "typecheck": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "setup-pi-settings": "scripts/setup-pi-settings.sh"
  },
  "description": "Pi extension package for recall MCP integration, subagent orchestration, and operational guard rails.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/altvoratech/recall-pi.git"
  },
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./.pi/extensions"
    ],
    "skills": [
      "./.agents/skills",
      "./.pi/skills"
    ],
    "prompts": [
      "./.pi/prompts"
    ],
    "themes": [
      "./.pi/themes"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "0.74.1",
    "@earendil-works/pi-ai": "0.74.1",
    "@earendil-works/pi-coding-agent": "0.74.1",
    "@earendil-works/pi-tui": "0.74.1",
    "@types/node": "^25.7.0",
    "typebox": "*",
    "typescript": "^6.0.3"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/altvoratech/recall-pi/issues"
  },
  "homepage": "https://github.com/altvoratech/recall-pi#readme"
}
